#!/bin/sh

PATH=/sbin:/bin:/usr/sbin:/usr/bin

NAME="S02kgdb"
SYSRQ_VALUE="${SYSRQ_VALUE:-1}"
KGDBOC_DEV="${KGDBOC_DEV:-ttymxc0}"
KGDBOC_BAUD="${KGDBOC_BAUD:-115200}"
KGDBOC_PARAM="${KGDBOC_PARAM:-${KGDBOC_DEV},${KGDBOC_BAUD}}"
KGDBOC_SYSFS="/sys/module/kgdboc/parameters/kgdboc"

log()
{
    echo "[$NAME] $*"
}

configure_panic()
{
    if [ -w /proc/sys/kernel/panic ]; then
        echo 0 > /proc/sys/kernel/panic || log "failed to disable panic auto-reboot"
    fi
}

enable_sysrq()
{
    if [ ! -w /proc/sys/kernel/sysrq ]; then
        log "/proc/sys/kernel/sysrq is not writable"
        return 0
    fi

    if echo "$SYSRQ_VALUE" > /proc/sys/kernel/sysrq; then
        log "sysrq enabled: $SYSRQ_VALUE"
    else
        log "failed to enable sysrq"
    fi
}

load_kgdboc()
{
    [ -e "$KGDBOC_SYSFS" ] && return 0

    if command -v modprobe >/dev/null 2>&1; then
        modprobe kgdboc kgdboc="$KGDBOC_PARAM" 2>/dev/null && return 0
    fi

    return 1
}

configure_kgdboc()
{
    if ! load_kgdboc; then
        log "kgdboc is not available"
        return 0
    fi

    if [ ! -w "$KGDBOC_SYSFS" ]; then
        log "$KGDBOC_SYSFS is not writable"
        return 0
    fi

    if echo "$KGDBOC_PARAM" > "$KGDBOC_SYSFS"; then
        log "kgdboc configured: $KGDBOC_PARAM"
    else
        log "failed to configure kgdboc: $KGDBOC_PARAM"
    fi
}

start()
{
    configure_panic
    enable_sysrq
    configure_kgdboc
}

stop()
{
    :
}

status()
{
    if [ -r /proc/sys/kernel/panic ]; then
        echo "panic: $(cat /proc/sys/kernel/panic)"
    else
        echo "panic: unavailable"
    fi

    if [ -r /proc/sys/kernel/sysrq ]; then
        echo "sysrq: $(cat /proc/sys/kernel/sysrq)"
    else
        echo "sysrq: unavailable"
    fi

    if [ -r "$KGDBOC_SYSFS" ]; then
        echo "kgdboc: $(cat "$KGDBOC_SYSFS")"
    else
        echo "kgdboc: unavailable"
    fi
}

case "$1" in
    start|"")
        start
        ;;
    stop)
        stop
        ;;
    restart|reload)
        start
        ;;
    status)
        status
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|reload|status}"
        exit 1
        ;;
esac
