#!/bin/sh

PATH=/sbin:/bin:/usr/sbin:/usr/bin

is_nfs_root()
{
    while read -r _ target fstype _; do
        [ "$target" = "/" ] || continue

        case "$fstype" in
            nfs|nfs4)
                return 0
                ;;
        esac
    done < /proc/mounts

    return 1
}

setup_loopback()
{
    if ! ip addr show dev lo | grep -q "inet 127.0.0.1/"; then
        ip addr add 127.0.0.1/8 dev lo 2>/dev/null || true
    fi

    ip link set lo up 2>/dev/null || true
}

start()
{
    printf "Starting network: "
    mkdir -p /run/network
    setup_loopback

    if is_nfs_root; then
        echo "skipped (NFS root)"
        return 0
    fi

    if ifup eth0; then
        echo "OK"
        return 0
    fi

    echo "FAIL"
    return 1
}

stop()
{
    printf "Stopping network: "

    if is_nfs_root; then
        echo "skipped (NFS root)"
        return 0
    fi

    if ifdown eth0; then
        echo "OK"
        return 0
    fi

    echo "FAIL"
    return 1
}

case "$1" in
    start|"")
        start
        ;;
    stop)
        stop
        ;;
    restart|reload)
        stop
        start
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|reload}"
        exit 1
        ;;
esac

exit $?
